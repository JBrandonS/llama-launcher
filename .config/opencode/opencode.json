{
  "$schema": "https://opencode.ai/config.json",
  "provider": {
    "llama.cpp": {
      "name": "Llama.cpp",
      "npm": "@ai-sdk/openai-compatible",
      "options": {
        "baseURL": "http://127.0.0.1:12345/v1"
      },
      "models": {
        "llama": {
          "name": "llama",
          "tools": true
        }
      }
    }
  },
  "mcp": {
    "sequential-thinking": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@modelcontextprotocol/server-sequential-thinking"
      ],
      "enabled": true,
      "timeout": 5000
    },
    "mcp-tools-py": {
      "type": "local",
      "command": [
        "/home/b/.local/bin/mcp-tools-py",
        "--project-dir",
        "/home/b/git/llama-launcher",
        "--venv-path",
        "/home/b/git/llama-launcher/.venv"
      ],
      "enabled": true,
      "timeout": 10000
    },
    "prompt-quality": {
      "type": "local",
      "command": ["mcp-prompt-quality"],
      "enabled": true
    },
    "mcp-shell-tools": {
      "type": "local",
      "command": [
        "mcp-shell-tools"
      ],
      "enabled": true
    }
  },
  "plugin": [
    "oh-my-openagent@latest",
    "opencode-mem"
  ]
}
