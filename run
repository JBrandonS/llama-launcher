#!/usr/bin/env bash
# Launch the standalone llama-launcher UI.
# Usage: ./run
# Or:    python run (falls through to launcher.py)

set -euo pipefail

SCRIPT_DIR="$(cd -- "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

cd "$SCRIPT_DIR"

# ── GPU disable for QtWebEngine (MUST precede Python/Qt load) ──
# Prevents vkCreateDevice/GBM crashes when Vulkan or hardware
# acceleration is unavailable (headless, CI, or missing drivers).
export QTWEBENGINE_DISABLE_GPU=1
export QTWEBENGINE_GPU_PROCESS=disabled
export QTWEBENGINE_SANDBOX=0
export QTWEBENGINE_CHROMIUM_FLAGS="--disable-gpu --disable-gpu-compositing --disable-gpu-driver-bug-workarounds --disable-gpu-sandbox"

if command -v python3 &>/dev/null; then
    python3 "$SCRIPT_DIR/ui/launcher.py" "$@"
elif command -v python &>/dev/null; then
    python "$SCRIPT_DIR/ui/launcher.py" "$@"
else
    echo "Error: python3 or python not found in PATH" >&2
    exit 1
fi
