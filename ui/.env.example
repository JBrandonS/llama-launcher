# Backend API base URL
VITE_API_BASE_URL=http://127.0.0.1:8290/api

# WebSocket URL for real-time updates
VITE_WS_URL=ws://127.0.0.1:8290/ws

# Polling intervals (milliseconds)
VITE_POLL_INTERVAL_SERVERS=5000
VITE_POLL_INTERVAL_METRICS=10000
VITE_POLL_INTERVAL_DAEMON=15000

# App
VITE_APP_NAME=Llama Launcher
VITE_APP_VERSION=0.1.0
